# ──────────────────────────────────────────────
# Base de datos PostgreSQL
# ──────────────────────────────────────────────
DB_USER=arqueos_user
DB_PASSWORD=change_me_strong_password

# ──────────────────────────────────────────────
# MinIO (almacenamiento de objetos)
# ──────────────────────────────────────────────
MINIO_USER=minio_admin
MINIO_PASSWORD=change_me_minio_password

# ──────────────────────────────────────────────
# JWT
# ──────────────────────────────────────────────
JWT_SECRET=change_me_with_at_least_64_random_characters_for_production
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_HOURS=24

# ──────────────────────────────────────────────
# Email OTP (para ETVs — MFA)
# ──────────────────────────────────────────────
OTP_EMAIL_HOST=smtp.gmail.com
OTP_EMAIL_PORT=587
OTP_EMAIL_USER=tu_correo@gmail.com
OTP_EMAIL_PASSWORD=app_password_aqui
OTP_EMAIL_FROM=Sistema Arqueos <tu_correo@gmail.com>

# ──────────────────────────────────────────────
# Entorno
# ──────────────────────────────────────────────
ENVIRONMENT=development
FRONTEND_ORIGIN=http://localhost:80
